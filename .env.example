# Copy to .env and fill in (.env is gitignored). Load before experiment scripts:
#   set -a && source .env && set +a
# (No python-dotenv — scripts read os.environ only.)

# Xiaomi MiMo Token Plan (tp-xxxxx) — China cluster default
MIMO_API_KEY=tp-your-key-here
MIMO_API_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# OpenAI-compatible (optional fallback for discovery; RQ1 LLM-as-judge OpenAI provider)
# OpenAI:
# OPENAI_API_KEY=sk-...
# OPENAI_JUDGE_MODEL=gpt-4o-mini
# DeepSeek:
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_JUDGE_MODEL=deepseek-chat

# Anthropic Claude (RQ1 LLM-as-judge — separate from MiMo discoverer)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-20250514

# Backend proxy (deterministic RQ1 smoke — CLI only; do NOT set in .env for live MiMo runs)
# Use: python -m experiments.rq1_batch_discover --backend-proxy --regenerate-all
# Optional: --sync-template to update data/eval/human_rq1_template.json
