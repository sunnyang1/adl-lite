# ADL Lite Coq Formalisation — Wrapper Makefile
#
# This is a thin wrapper around Makefile.coq, which is auto-generated by
# coq_makefile from _CoqProject. If _CoqProject changes, Makefile.coq is
# regenerated automatically.
#
# Usage:
#   make          — compile all .v files to .vo
#   make clean    — remove generated objects (.vo, .glob, .aux, html/)
#   make html     — generate Coqdoc HTML documentation
#   make validate — run coqchk on all compiled .vo files
#   make vos      — quick compilation (vos files, skip opaque proofs)
#   make vok      — check opaque proofs (vok files)
#   make TIMED=1  — build with per-file timing information
#
# The wrapper forwards ALL targets to Makefile.coq. You can also call
#   make -f Makefile.coq <target>
# directly if you prefer.

# Default target: build all .vo files
all: Makefile.coq
	$(MAKE) --no-print-directory -f Makefile.coq all

# Forward every target to Makefile.coq
%: Makefile.coq
	$(MAKE) --no-print-directory -f Makefile.coq $@

# Prevent the pattern rule from matching _CoqProject (source file, not a target).
_CoqProject:
	@:

# Regenerate Makefile.coq whenever _CoqProject changes.
# The generated Makefile.coq includes its own self-regeneration rule
# (Makefile.coq.conf: _CoqProject) so subsequent edits are handled.
Makefile.coq: _CoqProject
	@echo "Regenerating Makefile.coq from _CoqProject..."
	coq_makefile -f _CoqProject -o Makefile.coq

# Convenience shortcuts with explicit documentation
.PHONY: all clean html validate vos vok help

clean: Makefile.coq
	$(MAKE) --no-print-directory -f Makefile.coq clean

html: Makefile.coq
	$(MAKE) --no-print-directory -f Makefile.coq html

validate: Makefile.coq
	$(MAKE) --no-print-directory -f Makefile.coq validate

vos: Makefile.coq
	$(MAKE) --no-print-directory -f Makefile.coq vos

vok: Makefile.coq
	$(MAKE) --no-print-directory -f Makefile.coq vok

help:
	@echo "ADL Lite Coq formalisation build targets"
	@echo ""
	@echo "  make          — compile all .v files to .vo"
	@echo "  make clean    — remove all generated build artefacts"
	@echo "  make html     — generate Coqdoc HTML in html/"
	@echo "  make validate — run coqchk kernel verification"
	@echo "  make vos      — quick compilation (skip opaque proofs)"
	@echo "  make vok      — check opaque proofs only"
	@echo "  make TIMED=1  — build with timing output"
	@echo ""
	@echo "All other targets are forwarded to Makefile.coq."
	@echo "See README.md for detailed build instructions."
